      // =========================================================================

      // Pemetaan Warna Dinamis ke Tailwind CSS Classes (Sekarang menggunakan warna dominan Indigo)
      function getColorClasses(color) {
        const colorMap = {
          indigo: "bg-indigo-100 dark:bg-indigo-950/50 text-indigo-600 dark:text-indigo-400",
          sky: "bg-sky-100 dark:bg-sky-950/50 text-sky-600 dark:text-sky-400",
          violet: "bg-violet-100 dark:bg-violet-950/50 text-violet-600 dark:text-violet-400",
          amber: "bg-amber-100 dark:bg-amber-950/50 text-amber-600 dark:text-amber-400",
          pink: "bg-pink-100 dark:bg-pink-950/50 text-pink-600 dark:text-pink-400",
          teal: "bg-teal-100 dark:bg-teal-950/50 text-teal-600 dark:text-teal-400",
          rose: "bg-rose-100 dark:bg-rose-950/50 text-rose-600 dark:text-rose-400",
          purple: "bg-purple-100 dark:bg-purple-950/50 text-purple-600 dark:text-purple-400",
          orange: "bg-orange-100 dark:bg-orange-950/50 text-orange-600 dark:text-orange-400",
          cyan: "bg-cyan-100 dark:bg-cyan-950/50 text-cyan-600 dark:text-cyan-400",
          red: "bg-red-100 dark:bg-red-950/50 text-red-600 dark:text-red-400",
          slate: "bg-slate-100 dark:bg-slate-800/50 text-slate-600 dark:text-slate-450",
          blue: "bg-blue-100 dark:bg-blue-950/50 text-blue-600 dark:text-blue-400"
        };
        return colorMap[color] || "bg-slate-100 dark:bg-slate-800 text-slate-600 dark:text-slate-450";
      }

      // Inisialisasi Rendering Dinamis Berdasarkan CONFIG
      document.addEventListener("DOMContentLoaded", () => {
        // Render Meta & Judul Dokumen
        document.title = CONFIG.meta.title;
        document.getElementById('header-portal-title').textContent = CONFIG.meta.portalTitle;
        document.getElementById('header-ta-text').textContent = CONFIG.meta.academicYear;
        document.getElementById('profile-school-short').textContent = CONFIG.meta.schoolShort;
        document.getElementById('footer-school-name').textContent = CONFIG.meta.schoolLong;
        
        // Render Informasi Guru
        document.getElementById('validation-badge').textContent = CONFIG.teacher.statusBadge;
        document.getElementById('profile-teacher-name').textContent = CONFIG.teacher.name;
        document.getElementById('profile-teacher-role').textContent = CONFIG.teacher.role;
        document.getElementById('profile-location').textContent = CONFIG.meta.location;
        
        // Render Detail Metadata Verifikasi
        document.getElementById('meta-nip').textContent = CONFIG.teacher.nip;
        document.getElementById('meta-nuptk').textContent = CONFIG.teacher.nuptk;
        document.getElementById('meta-jabatan').textContent = CONFIG.teacher.jabatan; 
        document.getElementById('meta-school').textContent = CONFIG.meta.schoolLong;
        document.getElementById('meta-subject').textContent = CONFIG.teacher.subject;
        document.getElementById('meta-jjm').textContent = CONFIG.teacher.jjm;

        // Render Image Profil
        const imgContainer = document.getElementById('profile-img-container');
        imgContainer.innerHTML = `
          <img 
            id="profile-img" 
            src="${CONFIG.teacher.profileImg}" 
            alt="Foto Profil ${CONFIG.teacher.name}" 
            class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105" 
            onerror="handleImageError()"
          />
        `;

        // Render Tab Kategori
        renderCategories();

        // Render Daftar Tautan
        renderLinks();

        // Render Karakter G7KAIH ke Modal
        renderG7Characters();
      });

      // Render Tombol Tab Kategori secara Dinamis
      function renderCategories() {
        const container = document.getElementById('categories-container');
        container.innerHTML = CONFIG.categories.map((cat, index) => {
          const isActive = index === 0; // Default kategori pertama ("Semua Data") aktif
          const activeClass = isActive 
            ? "bg-indigo-600 text-white shadow-md shadow-indigo-500/20" 
            : "bg-white dark:bg-slate-800/40 hover:bg-white dark:hover:bg-slate-800 text-slate-600 dark:text-slate-300";
          
          return `
            <button 
              onclick="filterCategory('${cat.id}')" 
              id="tab-${cat.id}" 
              class="category-tab px-4 py-2 rounded-xl text-xs font-semibold whitespace-nowrap transition-all duration-300 ${activeClass}"
            >
              <i class="fa-solid ${cat.icon} mr-1"></i> ${cat.label}
            </button>
          `;
        }).join('');
      }

      // Render Daftar Tautan secara Dinamis
      function renderLinks() {
        const container = document.getElementById('links-container');
        container.innerHTML = CONFIG.links.map(link => {
          const isJavascript = link.url.startsWith('javascript:');
          const targetAttr = isJavascript ? '' : 'target="_blank"';
          const colorClass = getColorClasses(link.color);
          const textClass = colorClass.split(' ').pop(); // Ambil kelas warna teks
          
          return `
            <a 
              href="${link.url}" 
              ${targetAttr}
              class="link-card flex items-center justify-between p-4 bg-white/50 dark:bg-slate-900/20 hover:bg-indigo-50/40 dark:hover:bg-slate-800/80 border border-slate-200/40 dark:border-slate-800/30 rounded-2xl hover:translate-y-[-2px] hover:shadow-md transition-all duration-300 group" 
              data-category="${link.category}"
            >
              <div class="flex items-center gap-3">
                <div class="w-10 h-10 rounded-xl ${colorClass} flex items-center justify-center text-lg shadow-inner shrink-0">
                  <i class="fa-solid ${link.icon}"></i>
                </div>
                <div class="min-w-0">
                  <span class="font-bold text-xs md:text-sm block truncate text-slate-850 dark:text-slate-100">${link.title}</span>
                  <span class="text-[9px] ${textClass} uppercase tracking-wider font-extrabold flex items-center gap-1 mt-0.5">
                    <i class="fa-solid fa-circle-check"></i> ${link.status}
                  </span>
                </div>
              </div>
              <i class="fa-solid fa-chevron-right text-slate-400 group-hover:text-indigo-500 group-hover:translate-x-0.5 transition-all text-xs shrink-0"></i>
            </a>
          `;
        }).join('');
      }

      // Render Karakter G7KAIH ke dalam Modal
      function renderG7Characters() {
        const container = document.getElementById('g7kaih-list');
        container.innerHTML = CONFIG.g7Characters.map(char => {
          const colorClass = getColorClasses(char.color);
          return `
            <div class="flex gap-4 p-3 rounded-2xl bg-white/40 dark:bg-slate-900/40 border border-slate-200/30 dark:border-slate-800/20">
              <div class="w-10 h-10 rounded-xl ${colorClass} flex items-center justify-center text-lg shrink-0 shadow-inner">
                <i class="fa-solid ${char.icon} ${char.icon === 'fa-cloud-sun' ? 'animate-pulse' : ''}"></i>
              </div>
              <div>
                <h4 class="font-bold text-xs md:text-sm text-slate-900 dark:text-white">${char.name}</h4>
                <p class="text-xs text-slate-500 dark:text-slate-400 mt-1 leading-relaxed">${char.desc}</p>
              </div>
            </div>
          `;
        }).join('');
      }

      // Fungsi Pengontrol Modal Pop-up G7KAIH
      function openG7KaihModal() {
        const modal = document.getElementById('g7kaih-modal');
        modal.classList.remove('hidden');
        document.body.style.overflow = 'hidden'; 
      }

      // Tutup Modal Pop-up G7KAIH
      function closeG7KaihModal() {
        const modal = document.getElementById('g7kaih-modal');
        modal.classList.add('hidden');
        document.body.style.overflow = ''; 
      }

      // Penanganan Error Gambar (Inisial Nama Guru Sri Nurnawati Dahlan -> SN)
      function handleImageError() {
        // Membersihkan gelar jika ada koma untuk mengambil inisial murni dari nama depan
        const rawName = CONFIG.teacher.name.split(',')[0];
        const initials = rawName.split(' ').map(n => n[0]).slice(0, 2).join('').toUpperCase();
        const imgContainer = document.getElementById('profile-img-container');
        imgContainer.innerHTML = `
          <div class="w-full h-full bg-gradient-to-tr from-indigo-600 via-blue-600 to-sky-500 flex items-center justify-center text-white text-5xl font-extrabold tracking-wider animate-pulse-subtle">
            ${initials}
          </div>
        `;
      }

      // Filter Kategori Aktif
      let currentCategory = 'all';
      function filterCategory(category) {
        currentCategory = category;
        
        // Atur ulang warna/desain tab aktif dan non-aktif
        const tabs = document.querySelectorAll('.category-tab');
        tabs.forEach(tab => {
          tab.className = "category-tab px-4 py-2 rounded-xl text-xs font-semibold whitespace-nowrap transition-all duration-300 bg-white dark:bg-slate-800/40 hover:bg-white dark:hover:bg-slate-800 text-slate-600 dark:text-slate-300";
        });

        const activeTab = document.getElementById(`tab-${category}`);
        if (activeTab) {
          activeTab.className = "category-tab px-4 py-2 rounded-xl text-xs font-semibold whitespace-nowrap transition-all duration-300 bg-indigo-600 text-white shadow-md shadow-indigo-500/20";
        }

        filterLinks();
      }

      // Filter Pencarian & Kategori Gabungan
      function filterLinks() {
        const query = document.getElementById('search-input').value.toLowerCase();
        const cards = document.querySelectorAll('.link-card');
        let visibleCount = 0;

        cards.forEach(card => {
          const title = card.querySelector('span.font-bold').textContent.toLowerCase();
          const category = card.getAttribute('data-category');
          
          const matchesCategory = (currentCategory === 'all' || category === currentCategory);
          const matchesSearch = title.includes(query);

          if (matchesCategory && matchesSearch) {
            card.style.display = 'flex';
            visibleCount++;
          } else {
            card.style.display = 'none';
          }
        });

        const noResults = document.getElementById('no-results');
        const linksContainer = document.getElementById('links-container');
        if (visibleCount === 0) {
          noResults.classList.remove('hidden');
          linksContainer.classList.add('hidden');
        } else {
          noResults.classList.add('hidden');
          linksContainer.classList.remove('hidden');
        }
      }

      // Toggle Dark / Light Mode
      function toggleDarkMode() {
        const html = document.documentElement;
        const icon = document.getElementById('theme-icon');
        
        if (html.classList.contains('dark')) {
          html.classList.remove('dark');
          localStorage.setItem('theme', 'light');
          icon.className = 'fa-solid fa-moon';
        } else {
          html.classList.add('dark');
          localStorage.setItem('theme', 'dark');
          icon.className = 'fa-solid fa-sun';
        }
      }

      // Set Tema Saat Memuat Halaman Pertama Kali
      (function initTheme() {
        const savedTheme = localStorage.getItem('theme');
        const systemPrefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
        const icon = document.getElementById('theme-icon');
        
        if (savedTheme === 'dark' || (!savedTheme && systemPrefersDark)) {
          document.documentElement.classList.add('dark');
          if (icon) icon.className = 'fa-solid fa-sun';
        } else {
          document.documentElement.classList.remove('dark');
          if (icon) icon.className = 'fa-solid fa-moon';
        }
      })();

      // Tampilkan Toast Notifikasi Kustom
      function showToast(message) {
        const toast = document.getElementById('toast');
        const toastMsg = document.getElementById('toast-message');
        
        toastMsg.textContent = message;
        toast.classList.remove('opacity-0', 'pointer-events-none', 'translate-y-4');
        toast.classList.add('opacity-100', 'translate-y-0');
        
        setTimeout(() => {
          toast.classList.remove('opacity-100', 'translate-y-0');
          toast.classList.add('opacity-0', 'pointer-events-none', 'translate-y-4');
        }, 2500);
      }

      // Fungsi Salin Tautan Profil
      function shareProfile() {
        const dummyUrl = window.location.href;
        const dummyInput = document.createElement('input');
        document.body.appendChild(dummyInput);
        dummyInput.value = dummyUrl;
        dummyInput.select();
        document.execCommand('copy');
        document.body.removeChild(dummyInput);

        showToast('Tautan profil berhasil disalin!');
      }
    </script>
  </body>
</html>
